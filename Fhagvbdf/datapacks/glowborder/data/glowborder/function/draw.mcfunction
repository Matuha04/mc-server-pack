# Macro: summon the 12 glowing edge bars of the box, then colour + tag them.
# 4 edges along X
$summon block_display $(mnx) $(mny) $(mnz) {Tags:["gb_edge","gb_preview","gb_new"],Glowing:1b,view_range:4f,brightness:{block:15,sky:15},block_state:{Name:"minecraft:white_concrete"},transformation:{translation:[0f,0f,0f],left_rotation:[0f,0f,0f,1f],scale:[$(lx)f,0.1f,0.1f],right_rotation:[0f,0f,0f,1f]}}
