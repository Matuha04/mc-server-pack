{
  "schemaVersion": 1,
  "commandMode": "COMMAND_CUSTOM",
  "command": "smite",
  "permission": 2,
  "children": [
    {
      "child": "target",
      "type": "argument",
      "argumentType": "minecraft:word",
      "permission": 2,
      "actions": [
        {
          "command": "execute at {{target}} run summon minecraft:lightning_bolt",
          "commandType": "SERVER"
        },
        {
          "startTime": "200",
          "command": "execute at {{target}} run fill ~-4 ~-1 ~-4 ~4 ~6 ~4 minecraft:air replace minecraft:fire",
          "commandType": "SERVER",
          "messageIfSuccessful": "Smited {{target}} (no fire left behind)."
        }
      ]
    }
  ]
}
